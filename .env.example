# hermes-local-web-extract configuration
# Copy this file to .env and adjust values for your environment.
# Never commit .env to version control.

# Server binding
LOCAL_EXTRACT_HOST=0.0.0.0
LOCAL_EXTRACT_PORT=8090

# Logging
LOCAL_EXTRACT_LOG_LEVEL=INFO
# Set true only for debugging — URLs may contain tokens
LOCAL_EXTRACT_LOG_FULL_URLS=false

# Security: SSRF protection
# WARNING: Setting true allows extraction from private/local networks.
# Only enable on trusted, isolated networks where you understand the risk.
LOCAL_EXTRACT_ALLOW_PRIVATE_NETWORKS=false

# Proxy header trust (for rate limiting by real IP behind a reverse proxy)
# Only set true if you control the proxy and it sets X-Forwarded-For correctly.
LOCAL_EXTRACT_TRUST_PROXY_HEADERS=false

# Fetch limits
LOCAL_EXTRACT_MAX_BODY_MB=15
LOCAL_EXTRACT_MAX_PDF_MB=20
LOCAL_EXTRACT_TIMEOUT_SECONDS=20
LOCAL_EXTRACT_MAX_TIMEOUT_SECONDS=60
LOCAL_EXTRACT_MAX_REDIRECTS=5
LOCAL_EXTRACT_MAX_CONTENT_CHARS=200000

# Concurrency and rate limiting
LOCAL_EXTRACT_RATE_LIMIT_PER_MINUTE=60
LOCAL_EXTRACT_CONCURRENCY=8

# Caching (disabled by default)
LOCAL_EXTRACT_CACHE_ENABLED=false
LOCAL_EXTRACT_CACHE_TTL_SECONDS=3600
# backend: memory (only option in base install)
LOCAL_EXTRACT_CACHE_BACKEND=memory

# Browser / JavaScript rendering (requires browser Docker profile)
LOCAL_EXTRACT_BROWSER_ENABLED=false

# Robots.txt (disabled by default — users are responsible for compliance)
LOCAL_EXTRACT_RESPECT_ROBOTS_TXT=false
